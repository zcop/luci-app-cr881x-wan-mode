#!/bin/sh

set -e

. /lib/functions/system.sh
. /lib/functions/ipv4.sh

PORTS="lan1 lan2 lan3 wan"

usage() {
	cat <<'EOF'
Usage:
  cr881x-wan-mode status
  cr881x-wan-mode all-lan [--no-restart]
  cr881x-wan-mode single-wan <port> [--no-restart]
  cr881x-wan-mode dual-wan <port1> <port2> [--random-mac] [--no-restart]

Valid ports: lan1 lan2 lan3 wan

Examples:
  cr881x-wan-mode all-lan
  cr881x-wan-mode single-wan wan
  cr881x-wan-mode dual-wan wan lan3
  cr881x-wan-mode dual-wan wan lan3 --random-mac
EOF
}

die() {
	echo "cr881x-wan-mode: $*" >&2
	exit 1
}

uci_delete_quiet() {
	uci -q delete "$1" >/dev/null 2>&1 || true
}

valid_port() {
	case " $PORTS " in
	*" $1 "*)
		return 0
		;;
	esac
	return 1
}

list_minus() {
	local skip1="$1"
	local skip2="$2"
	local out=""
	local p

	for p in $PORTS; do
		[ "$p" = "$skip1" ] && continue
		[ -n "$skip2" ] && [ "$p" = "$skip2" ] && continue
		out="$out $p"
	done

	echo "${out# }"
}

ensure_br_lan() {
	uci -q set network.br_lan='device'
	uci -q set network.br_lan.name='br-lan'
	uci -q set network.br_lan.type='bridge'

	uci -q set network.lan='interface'
	uci -q set network.lan.device='br-lan'
	[ -n "$(uci -q get network.lan.proto)" ] || uci -q set network.lan.proto='static'
	normalize_lan_ipv4
}

normalize_lan_ipv4() {
	local raw ipaddr suffix netmask __tmp

	[ "$(uci -q get network.lan.proto)" = "static" ] || return 0

	raw="$(uci -q get network.lan.ipaddr || true)"
	raw="${raw%% *}"

	case "$raw" in
	*/*)
		ipaddr="${raw%/*}"
		suffix="${raw#*/}"
		case "$suffix" in
		*.*.*.*)
			netmask="$suffix"
			;;
		*)
			if [ "$suffix" -ge 0 ] 2>/dev/null && [ "$suffix" -le 32 ] 2>/dev/null; then
				prefix2netmask netmask "$suffix"
			fi
			;;
		esac
		;;
	*)
		ipaddr="$raw"
		netmask="$(uci -q get network.lan.netmask || true)"
		;;
	esac

	if ! str2ip __tmp "$ipaddr"; then
		ipaddr='192.168.2.1'
	fi
	if ! str2ip __tmp "$netmask"; then
		netmask='255.255.255.0'
	fi

	uci_delete_quiet network.lan.ipaddr
	uci -q set network.lan.ipaddr="$ipaddr"
	uci -q set network.lan.netmask="$netmask"
}

set_br_lan_ports() {
	local ports="$1"
	local p

	uci_delete_quiet network.br_lan.ports
	for p in $ports; do
		uci -q add_list network.br_lan.ports="$p"
	done
}

ensure_wan_zone() {
	uci -q set firewall.wan='zone'
	uci -q set firewall.wan.name='wan'
	[ -n "$(uci -q get firewall.wan.input)" ] || uci -q set firewall.wan.input='REJECT'
	[ -n "$(uci -q get firewall.wan.output)" ] || uci -q set firewall.wan.output='ACCEPT'
	[ -n "$(uci -q get firewall.wan.forward)" ] || uci -q set firewall.wan.forward='REJECT'
	[ "$(uci -q get firewall.wan.masq)" = "1" ] || uci -q set firewall.wan.masq='1'
	[ "$(uci -q get firewall.wan.mtu_fix)" = "1" ] || uci -q set firewall.wan.mtu_fix='1'
}

set_wan_zone_networks() {
	local nets="$1"
	local n

	ensure_wan_zone
	uci_delete_quiet firewall.wan.network
	for n in $nets; do
		uci -q add_list firewall.wan.network="$n"
	done
}

set_wan_v4v6() {
	local iface="$1"
	local dev="$2"
	local iface6="${iface}6"

	[ "$iface" = "wan2" ] && iface6="wan2_6"

	uci -q set network."$iface"='interface'
	uci -q set network."$iface".device="$dev"
	uci -q set network."$iface".proto='dhcp'

	uci -q set network."$iface6"='interface'
	uci -q set network."$iface6".device='@'"$iface"
	uci -q set network."$iface6".proto='dhcpv6'
}

get_base_macaddr() {
	local mac=""

	mac="$(get_mac_label)"
	[ -n "$mac" ] || mac="$(cat /sys/class/net/wan/address 2>/dev/null)"
	[ -n "$mac" ] || mac="$(cat /sys/class/net/lan1/address 2>/dev/null)"

	[ -n "$mac" ] && macaddr_canonicalize "$mac"
}

ensure_unique_dual_wan_macs() {
	local cur1 cur2 base mac1 mac2

	cur1="$(uci -q get network.wan.macaddr || true)"
	cur2="$(uci -q get network.wan2.macaddr || true)"

	if [ -n "$cur1" ] && [ -n "$cur2" ] && [ "$cur1" != "$cur2" ]; then
		return 0
	fi

	if [ -n "$cur1" ] && [ -n "$cur2" ] && [ "$cur1" = "$cur2" ]; then
		mac1="$cur1"
		mac2="$(macaddr_add "$cur1" 1)"
	elif [ -n "$cur1" ]; then
		mac1="$cur1"
		mac2="$(macaddr_add "$cur1" 1)"
	elif [ -n "$cur2" ]; then
		mac2="$cur2"
		mac1="$(macaddr_add "$cur2" 1)"
	else
		base="$(get_base_macaddr)"
		[ -n "$base" ] || return 0
		base="$(macaddr_unsetbit_mc "$(macaddr_setbit_la "$base")")"
		mac1="$(macaddr_add "$base" 1)"
		mac2="$(macaddr_add "$base" 2)"
	fi

	uci -q set network.wan.macaddr="$mac1"
	uci -q set network.wan2.macaddr="$mac2"
}

set_random_dual_wan_macs() {
	local mac1 mac2

	mac1="$(macaddr_random)"
	mac2="$(macaddr_random)"
	while [ "$mac2" = "$mac1" ]; do
		mac2="$(macaddr_random)"
	done

	uci -q set network.wan.macaddr="$mac1"
	uci -q set network.wan2.macaddr="$mac2"
}

apply_all_lan() {
	ensure_br_lan
	set_br_lan_ports "$PORTS"

	uci_delete_quiet network.wan
	uci_delete_quiet network.wan6
	uci_delete_quiet network.wan2
	uci_delete_quiet network.wan2_6

	set_wan_zone_networks ""
}

apply_single_wan() {
	local wanp="$1"
	local lan_ports

	lan_ports="$(list_minus "$wanp" "")"

	ensure_br_lan
	set_br_lan_ports "$lan_ports"

	set_wan_v4v6 wan "$wanp"
	uci_delete_quiet network.wan2
	uci_delete_quiet network.wan2_6

	set_wan_zone_networks "wan wan6"
}

apply_dual_wan() {
	local wan1="$1"
	local wan2="$2"
	local lan_ports
	local random_mac="$3"

	lan_ports="$(list_minus "$wan1" "$wan2")"

	ensure_br_lan
	set_br_lan_ports "$lan_ports"

	set_wan_v4v6 wan "$wan1"
	set_wan_v4v6 wan2 "$wan2"
	if [ "$random_mac" = "1" ]; then
		set_random_dual_wan_macs
	else
		ensure_unique_dual_wan_macs
	fi

	set_wan_zone_networks "wan wan6 wan2 wan2_6"
}

show_status() {
	local br_ports
	local wan_dev
	local wan2_dev
	local mode

	br_ports="$(uci -q get network.br_lan.ports | tr '\n' ' ' | sed 's/[[:space:]]\\+/ /g; s/^ //; s/ $//')"
	wan_dev="$(uci -q get network.wan.device || true)"
	wan2_dev="$(uci -q get network.wan2.device || true)"

	mode="custom"
	if [ "$br_ports" = "$PORTS" ] && [ -z "$wan_dev" ] && [ -z "$wan2_dev" ]; then
		mode="all-lan"
	elif [ -n "$wan_dev" ] && [ -z "$wan2_dev" ]; then
		mode="single-wan"
	elif [ -n "$wan_dev" ] && [ -n "$wan2_dev" ]; then
		mode="dual-wan"
	fi

	echo "board: $(board_name)"
	echo "mode: $mode"
	echo "br-lan ports: ${br_ports:-<unset>}"
	echo "wan: ${wan_dev:-<unset>}"
	echo "wan2: ${wan2_dev:-<unset>}"
}

commit_and_maybe_restart() {
	local no_restart="$1"

	uci commit network
	uci commit firewall

	if [ "$no_restart" = "1" ]; then
		echo "Applied UCI changes without restart (--no-restart)."
		return 0
	fi

	/etc/init.d/network restart
	/etc/init.d/firewall restart
}

require_board() {
	local b
	b="$(board_name)"
	[ "$b" = "xiaomi,cr881x" ] || die "unsupported board '$b' (expected xiaomi,cr881x)"
}

cmd="${1:-status}"

case "$cmd" in
status)
	require_board
	show_status
	;;
all-lan)
	require_board
	[ "$2" = "--no-restart" ] && no_restart=1 || no_restart=0
	apply_all_lan
	commit_and_maybe_restart "$no_restart"
	show_status
	;;
single-wan)
	require_board
	wanp="$2"
	[ -n "$wanp" ] || die "missing WAN port"
	valid_port "$wanp" || die "invalid port '$wanp'"
	[ "$3" = "--no-restart" ] && no_restart=1 || no_restart=0
	apply_single_wan "$wanp"
	commit_and_maybe_restart "$no_restart"
	show_status
	;;
dual-wan)
	require_board
	wan1="$2"
	wan2="$3"
	shift 3
	[ -n "$wan1" ] || die "missing WAN1 port"
	[ -n "$wan2" ] || die "missing WAN2 port"
	valid_port "$wan1" || die "invalid WAN1 port '$wan1'"
	valid_port "$wan2" || die "invalid WAN2 port '$wan2'"
	[ "$wan1" = "$wan2" ] && die "WAN1 and WAN2 must be different ports"
	no_restart=0
	random_mac=0
	while [ $# -gt 0 ]; do
		case "$1" in
		--no-restart)
			no_restart=1
			;;
		--random-mac)
			random_mac=1
			;;
		esac
		shift
	done
	apply_dual_wan "$wan1" "$wan2" "$random_mac"
	commit_and_maybe_restart "$no_restart"
	show_status
	;;
help|-h|--help)
	usage
	;;
*)
	usage
	exit 1
	;;
esac
